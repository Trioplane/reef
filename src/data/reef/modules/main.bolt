LOGGER = Logger("reef", false)
DEV_LOGGER = Logger("reef_dev")

function reef:load:
    function reef:api/load
    function reef:zzzinternals/load

    LOGGER.info("@a[tag=reef.permissions.see_debug]", f"Loaded! (version {ctx.project_version})")

function reef:tick:
    ...

function reef:uninstall:
