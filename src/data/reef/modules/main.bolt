LOGGER = Logger("reef", false)
DEV_LOGGER = Logger("reef_dev")

G_ENVIRONMENT = G_ENVIRONMENT_TYPES.development

function reef:load:
    function reef:api/load
    function reef:zzzinternals/load

    LOGGER.info("@a[tag=reef.permissions.read_logs]", f"Loaded! (version {ctx.project_version})")

function reef:tick:
    ...

append function_tag minecraft:load {
    "values": [
        "reef:load"
    ]
}

append function_tag minecraft:tick {
    "values": [
        "reef:tick"
    ]
}