{
    "author": "Trplnr",
    "name": "Reef",
    "description": "Create stunning presentations completely in vanilla Minecraft: Java Edition",
    "version": "1.0.0-beta4",
    "minecraft": "26.1",
    "data_pack": {
        "load": ["src"],
        "min_format": [101,0],
        "max_format": [101,0]
    },
    "resource_pack": {
        "load": ["src"],
        "min_format": [101,0],
        "max_format": [101,0]
    },
    "pipeline": ["mecha"],
    "require": [
        "reef",
        "bolt",
        "bolt_expressions",
        "bolt_native_macros",
        "beet.contrib.livereload"
    ],
    "meta": {
        "bolt": {
            "entrypoint": "reef:*",
            "prelude": "reef:prelude"
        },
        "reef": {
            "tint": 66046,
            "pdf": {
                "poppler_path": "C:/development/libraries/poppler-26.02.0/Library/bin"
            }
        }
    },
    "output": "build"
}